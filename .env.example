# Required only for eBird region codes (e.g. US-MA). Get a free key at:
# https://ebird.org/api/keygen
# EBIRD_API_KEY=your_key_here

# All CLI options can also be set as environment variables.
# CLI flags always take precedence. See README for the full list.
# AVIANKI_LOCATION=US-MA
# AVIANKI_LIMIT=50
# AVIANKI_OUTPUT=Birds_MyLocation.apkg
# AVIANKI_DECK_NAME=My Birds
# AVIANKI_DELAY=0.5
# AVIANKI_WORK_DIR=/tmp/avianki
# AVIANKI_MEDIA_DIR=/tmp/avianki/media
# AVIANKI_JSON_FILE=/tmp/avianki/birds.json
# AVIANKI_LOG_FILE=/tmp/avianki/avianki.log
# AVIANKI_NO_AUDIO=1
# AVIANKI_NO_IMAGES=1
# AVIANKI_EPHEMERAL=1
# AVIANKI_NO_CACHE=1
# AVIANKI_VERBOSE=1
# AVIANKI_QUIET=1

# For development only
# UV_PUBLISH_TOKEN=pypi-your_key_here